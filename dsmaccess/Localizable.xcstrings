    "La tâche « %@ » sera définitivement supprimée de USB Copy. Cette action est irréversible. Vérifiez que vous n’avez plus besoin de sa configuration ni de son historique." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The “%1$@” task will be permanently removed from USB Copy. This action cannot be undone. Make sure you no longer need its configuration or history."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tâche « %@ » sera définitivement supprimée de USB Copy. Cette action est irréversible. Vérifiez que vous n’avez plus besoin de sa configuration ni de son historique."
          }
        }
